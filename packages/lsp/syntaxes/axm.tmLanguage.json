{
  "scopeName": "source.axm",
  "patterns": [
    { "include": "#comment" },
    { "include": "#statement" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.axm"
    },
    "statement": {
      "match": "^([a-zA-Z0-9_-]+)\\s+(.*)",
      "captures": {
        "1": { "name": "entity.name.tag.id.axm" },
        "2": { "name": "string.unquoted.body.axm", "patterns": [{ "include": "#reference" }] }
      }
    },
    "reference": {
      "match": "\\{([a-zA-Z0-9_-]+)\\}",
      "name": "variable.other.reference.axm",
      "captures": {
        "1": { "name": "entity.name.tag.id.axm" }
      }
    }
  }
}
