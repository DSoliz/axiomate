{
  "scopeName": "source.axm",
  "patterns": [
    { "include": "#comment" },
    { "include": "#statement-stm" },
    { "include": "#statement-rsk" },
    { "include": "#statement-unk" },
    { "include": "#statement-asm" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.axm"
    },
    "statement-stm": {
      "match": "^(stm)(\\s+)([a-zA-Z0-9][a-zA-Z0-9_-]*)(\\s*=\\s*)(.*)",
      "captures": {
        "1": { "name": "keyword.control.stm.axm" },
        "3": { "name": "entity.name.tag.id.axm" },
        "4": { "name": "keyword.operator.assignment.axm" },
        "5": { "name": "string.unquoted.body.axm", "patterns": [{ "include": "#reference" }] }
      }
    },
    "statement-rsk": {
      "match": "^(rsk)(\\s+)([a-zA-Z0-9][a-zA-Z0-9_-]*)(\\s*=\\s*)(.*)",
      "captures": {
        "1": { "name": "markup.deleted.rsk.axm" },
        "3": { "name": "entity.name.tag.id.axm" },
        "4": { "name": "keyword.operator.assignment.axm" },
        "5": { "name": "string.unquoted.body.axm", "patterns": [{ "include": "#reference" }] }
      }
    },
    "statement-unk": {
      "match": "^(unk)(\\s+)([a-zA-Z0-9][a-zA-Z0-9_-]*)(\\s*=\\s*)(.*)",
      "captures": {
        "1": { "name": "markup.changed.unk.axm" },
        "3": { "name": "entity.name.tag.id.axm" },
        "4": { "name": "keyword.operator.assignment.axm" },
        "5": { "name": "string.unquoted.body.axm", "patterns": [{ "include": "#reference" }] }
      }
    },
    "statement-asm": {
      "match": "^(asm)(\\s+)([a-zA-Z0-9][a-zA-Z0-9_-]*)(\\s*=\\s*)(.*)",
      "captures": {
        "1": { "name": "markup.inserted.asm.axm" },
        "3": { "name": "entity.name.tag.id.axm" },
        "4": { "name": "keyword.operator.assignment.axm" },
        "5": { "name": "string.unquoted.body.axm", "patterns": [{ "include": "#reference" }] }
      }
    },
    "reference": {
      "match": "\\$\\{([a-zA-Z0-9_-]+)\\}",
      "name": "variable.other.reference.axm",
      "captures": {
        "1": { "name": "entity.name.tag.id.axm" }
      }
    }
  }
}
